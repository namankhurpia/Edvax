# ===== Deployment config (root) =====
# Copy to .env on the server and fill real values. NEVER commit .env.

# Postgres (data lives in the edvax_pgdata Docker volume — persists across updates)
POSTGRES_USER=edvax
POSTGRES_PASSWORD=use_a_strong_password_here
POSTGRES_DB=edvax

# Public site port on the host (open this in your firewall)
WEB_PORT=80

# Must match the public URL the browser uses (for CORS + cookies)
# --- Domain + HTTPS (Caddy) ---
# Your domain. Caddy auto-provisions a free Let's Encrypt cert for it.
DOMAIN=edvax.in
# Email Let's Encrypt uses for renewal notices.
TLS_EMAIL=edvax.info@gmail.com

# Must match how the browser reaches the site. With HTTPS via Caddy, use https://.
CORS_ORIGIN=https://edvax.in

# true once HTTPS is live (Caddy). Keep false only while testing on plain HTTP.
COOKIE_SECURE=true

# WEB_PORT is no longer used for publishing — Caddy owns 80/443. Left for reference.

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# First admin (created on first boot / `npm run seed`)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong

# Razorpay (India / UPI) — fill when ready
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (delivers Zoom recording links on payment)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="EDVAX <no-reply@yourdomain.com>"
