# ===== LOCAL run config =====
# Copy this to ".env" to run locally with Docker:  cp .env.local.example .env
# These are SAFE local defaults. Do NOT use this file in production.

# Postgres — local dev credentials (data persists in the edvax_pgdata volume)
POSTGRES_USER=edvax
POSTGRES_PASSWORD=edvax_local_password
POSTGRES_DB=edvax

# Open the site on http://localhost:8080
WEB_PORT=8080

# Must match how the browser reaches the site (for CORS + cookies)
CORS_ORIGIN=http://localhost:8080

# Auth secret (this is a throwaway local value — fine for local testing)
JWT_SECRET=178edd630d5f62d34aeb50ac5a61b8fc498e4282ba63a9741531b5ca55bf7db8
JWT_EXPIRES_IN=7d

# First admin account — created when you run ./deploy.sh seed
ADMIN_EMAIL=admin@edvax.local
ADMIN_PASSWORD=admin12345

# Razorpay — leave blank locally; checkout will show a clear "not configured" msg
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email — leave blank locally; Zoom-link emails are logged to the API console instead
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="EDVAX Local <no-reply@edvax.local>"
