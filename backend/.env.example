# ===== EDVAX API configuration =====
# Copy to .env and fill real values. NEVER commit .env.

PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# Auth — generate a long random string for production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Database (PostgreSQL). In Docker, host is the service name "db".
DATABASE_URL=postgres://edvax:edvax_password@localhost:5432/edvax

# First admin bootstrap (created on `npm run seed` if not present)
ADMIN_EMAIL=admin@edvax.example.com
ADMIN_PASSWORD=change_me_now

# ===== Razorpay (India / UPI) — placeholders =====
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# ===== Email (Zoom recording-link delivery) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASS=replace_me
MAIL_FROM="EDVAX <no-reply@edvax.example.com>"
